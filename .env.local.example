# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API Configuration (Backend only - DO NOT expose this in browser)
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key

# Anthropic Model Configuration
# Try: claude-opus, claude-sonnet, claude-3-opus-20250219, claude-3-5-sonnet-20241022, etc.
ANTHROPIC_MODEL_NAME=claude-opus

# Backend API URL (Frontend - leave blank for localhost:3001)
VITE_API_URL=

# App Configuration
VITE_API_TIMEOUT=30000
VITE_APP_NAME=Emotion Wheel
